  "doctrine": [
    {
      "b": "GPA is the floor, not the goal.",
      "s": "3.7+ keeps every door open. Cheapest edge you have — protect it first."
    },
    {
      "b": "Follow up within 24 hours.",
      "s": "Thank-you note the same day you meet, interview, or get advice. This alone beats most peers."
    },
    {
      "b": "Depth beats a long list.",
      "s": "One leadership role + one placed case comp outweigh eight clubs you merely attended."
    },
    {
      "b": "Ship proof, not plans.",
      "s": "A public dashboard, a repo, a placed comp. Recruiters trust artifacts, not adjectives."
    },
    {
      "b": "Referrals > cold apps.",
      "s": "Find a Terry alum before you hit submit. One warm intro beats fifty portals."
    },
    {
      "b": "Rush both. Fully.",
      "s": "You only get bids from rooms you show up to. Non-negotiable for the first two weeks."
    }
